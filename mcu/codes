#include <TinyGPS++.h>

TinyGPSPlus gps;

// ESP32-C3 UART objects
HardwareSerial GPS(1);
HardwareSerial GSM(2);

// Pin definitions
#define SOS_BUTTON 2
#define BUZZER_PIN 10

// GPS pins
#define GPS_RX 6
#define GPS_TX 7

// GSM pins
#define GSM_RX 20
#define GSM_TX 21

// Change this
String guardian = "+911234567890";

void setup() {

  Serial.begin(115200);

  pinMode(SOS_BUTTON, INPUT_PULLUP);
  pinMode(BUZZER_PIN, OUTPUT);

  digitalWrite(BUZZER_PIN, LOW);

  GPS.begin(
      9600,
      SERIAL_8N1,
      GPS_RX,
      GPS_TX
  );

  GSM.begin(
      9600,
      SERIAL_8N1,
      GSM_RX,
      GSM_TX
  );

  delay(3000);

  Serial.println("SOS Device Ready");

  testGSM();
}

void loop() {

  while(GPS.available()) {
    gps.encode(GPS.read());
  }

  if(digitalRead(SOS_BUTTON)==LOW){

      triggerSOS();

      delay(5000);
  }
}

void triggerSOS(){

  Serial.println("SOS ACTIVATED");

  vibrate();

  float lat=0;
  float lng=0;

  bool locationFound=false;

  unsigned long timer=millis();

  Serial.println("Searching GPS...");

  while(millis()-timer<15000){

      while(GPS.available()){

          gps.encode(GPS.read());

          if(gps.location.isValid()){

              lat=gps.location.lat();
              lng=gps.location.lng();

              locationFound=true;
              break;
          }
      }

      if(locationFound)
      break;
  }

  String msg;

  if(locationFound){

      String maps=
      "https://maps.google.com/?q="
      +String(lat,6)
      +","
      +String(lng,6);

      msg=
      "EMERGENCY! Need help! Location: "
      +maps;

  }
  else{

      msg=
      "EMERGENCY! Need help! GPS location unavailable";
  }

  sendSMS(msg);

  delay(2000);

  callGuardian();

  Serial.println("Finished");
}

void sendSMS(String text){

    Serial.println("Sending SMS");

    GSM.println("AT");
    delay(1000);

    GSM.println("AT+CMGF=1");
    delay(1000);

    GSM.print("AT+CMGS=\"");
    GSM.print(guardian);
    GSM.println("\"");

    delay(1000);

    GSM.print(text);

    delay(500);

    GSM.write(26);

    delay(5000);

    Serial.println("SMS sent");
}

void callGuardian(){

    Serial.println("Calling");

    GSM.print("ATD");
    GSM.print(guardian);
    GSM.println(";");

    delay(15000);

    GSM.println("ATH");

}

void vibrate(){

  for(int i=0;i<5;i++){

      digitalWrite(BUZZER_PIN,HIGH);
      delay(200);

      digitalWrite(BUZZER_PIN,LOW);
      delay(200);
  }

}

void testGSM(){

    GSM.println("AT");

    delay(1000);

    while(GSM.available()){

        Serial.write(GSM.read());
    }
}
